# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Public URL of the app (used in email links, CORS, etc.)
APP_URL=https://your-domain.com

# Comma-separated list of allowed origins for CORS (managed mode only)
# Leave blank for single-domain deployments behind Nginx
ALLOWED_ORIGINS=

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Setting this env var activates managed (PostgreSQL) mode automatically.
# (For Docker Compose, point the host at the `db` service: ...@db:5432/pf)
DATABASE_URL=postgres://pf:changeme@postgres:5432/pf

# PF_DATABASE_URL takes PRECEDENCE over DATABASE_URL when both are set.
# Leave unset unless you need to override DATABASE_URL for a specific process.
# PF_DATABASE_URL=

# PostgreSQL service credentials. When running Postgres in Docker (the `db`
# service in docker-compose.yml), these seed the database on first boot.
# For an external Postgres, set DATABASE_URL above to match your server.
POSTGRES_DB=pf
POSTGRES_USER=pf
POSTGRES_PASSWORD=changeme

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret for signing JWT session tokens.
# Generate with: openssl rand -hex 32
PF_JWT_SECRET=change-this-to-a-random-64-char-hex-string

# Pepper for scrypt password hashing (≥32 chars). Required in production —
# the auth module throws at boot if missing. Rotating this value invalidates
# every stored password hash and every encrypted-field envelope, so set it
# once per environment and back it up. Generate with: openssl rand -hex 32
PF_PEPPER=change-this-to-a-random-64-char-hex-string

# Wraps service-tier (sv1:) staged-import envelopes for email-imports that
# arrive without an active user DEK (≥32 chars). Required in production —
# the staging module throws at boot if missing. Rotating invalidates every
# pending service-tier staged batch. Also set on `finlynq-demo-reset.service`
# (separate systemd unit — does NOT inherit from the main service env).
# Generate with: openssl rand -hex 32
PF_STAGING_KEY=change-this-to-a-random-64-char-hex-string

# Pepper version 2 (≥32 chars). Only set during a pepper rotation, alongside
# PF_PEPPER. Required only if any user row already carries pepper_version=2.
# PF_PEPPER_V2=

# When set to N>1, login lazily re-wraps each user's DEK to pepper version N on
# their next sign-in. Opt-in: leave unset to skip rotation entirely.
# PF_PEPPER_TARGET_VERSION=

# ─── Stdio MCP server (self-hosted desktop/CLI clients) ───────────────────────
# Which user the stdio MCP server serves. Required ONLY when running the MCP
# server over stdio (npm run build:mcp); the process exits if it's missing.
# Not needed for the web app or the HTTP MCP transport.
# PF_USER_ID=

# ─── SMTP (password reset emails) ────────────────────────────────────────────
# Leave blank to disable email-based password reset.
PF_SMTP_HOST=smtp.example.com
PF_SMTP_PORT=587
PF_SMTP_USER=user@example.com
PF_SMTP_PASS=your-smtp-password
PF_SMTP_FROM=noreply@your-domain.com

# ─── Email Import (Resend Inbound) ────────────────────────────────────────────
# Domain used for generated import addresses (e.g. import-abc123@<domain>).
# Managed default is finlynq.com; self-hosters can point their own MX at the
# webhook and set this to their domain.
IMPORT_EMAIL_DOMAIN=finlynq.com
# Local-part prefix for generated import addresses (import-<hex>@<domain>).
# Defaults to "import-"; set per environment to avoid collisions.
# IMPORT_EMAIL_LOCALPART_PREFIX=import-
# Inbound email provider: "resend" (Resend Inbound + svix, default) or
# "self-smtp" (a self-hosted SMTP relay that HMAC-signs the push).
# INBOUND_EMAIL_PROVIDER=resend
# HMAC secret (≥16 chars) for the "self-smtp" inbound path. Must match the
# value on the relay. Required only when INBOUND_EMAIL_PROVIDER=self-smtp.
# FINLYNQ_INBOUND_SECRET=
# Svix signing secret from the Resend Inbound webhook config. Required in prod
# (the webhook returns 500 "Webhook not configured" without it). Format:
# `whsec_<base64>`. Get this from Resend dashboard → Inbound route → signing secret.
RESEND_WEBHOOK_SECRET=
# Resend REST API key. Optional — enables bounce emails for unknown trash
# addresses. We only bounce to senders whose SPF + DKIM pass (no backscatter).
RESEND_API_KEY=
# Return-path for bounce emails. Defaults to mailer-daemon@finlynq.com.
BOUNCE_FROM=

# ─── Backups ──────────────────────────────────────────────────────────────────
# How many days to retain local backup files (default: 7)
BACKUP_RETENTION_DAYS=7
# Path to a gpg-symmetric passphrase file. When readable, deploy.sh pipes
# pg_dump through `gpg --symmetric` to encrypt backups at rest. Backups stay
# plaintext (with a WARNING) if unset. Store the key off-box too.
# BACKUP_ENCRYPTION_KEY_FILE=/etc/finlynq/backup-key

# ─── Donations / Open Source ───────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_REPO=https://github.com/finlynq/finlynq
NEXT_PUBLIC_DONATION_GITHUB=https://github.com/sponsors/finlynq
NEXT_PUBLIC_DONATION_KOFI=https://ko-fi.com/finlynq
